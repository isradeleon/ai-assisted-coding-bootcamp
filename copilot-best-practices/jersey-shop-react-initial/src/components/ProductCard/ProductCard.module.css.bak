.product {
  padding-top: 12px;
  border: 1px solid lightgrey;
  margin: 12px;
  flex: 0 0 calc(33.333% - 36px);
  cursor: pointer;
  text-align: center;
  border-radius: 20px 20px 0 0;
}

.inBag {
  border: 3px solid rgb(220, 75, 39);
}

.photo img {
  max-width: 140px;
}

.description {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  font-size: 16px;
  line-height: 15px;
}

.name {
  font-size: 18px;
  margin-bottom: 6px;
}

.price {
  font-weight: bold;
  margin: 4px auto;
}

.quantityArea {
  padding: 12px;
  margin-top: 16px;
  box-sizing: border-box;
  width: 100%;
  font-size: 18px;
}

